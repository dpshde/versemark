{
  "name": "@versemark/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "expo": {
    "install": {
      "exclude": [
        "react-native-screens"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios:simulator": "expo run:ios",
    "ios": "expo run:ios --configuration Release",
    "ios:device": "bash ./scripts/run-ios-device.sh \"DPS iPhone\"",
    "ios:device:any": "bash ./scripts/run-ios-device.sh",
    "ios:device:debug": "VM_IOS_DEBUG=1 bash ./scripts/run-ios-device.sh \"DPS iPhone\"",
    "prebuild:ios": "expo prebuild --platform ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc -p tsconfig.json --pretty false --noEmit",
    "export": "expo export --platform web --output-dir dist-export",
    "test": "vitest run && node ./scripts/smoke-core.mjs",
    "test:unit": "vitest run",
    "test:smoke": "node ./scripts/smoke-core.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "55.0.11",
    "@legendapp/list": "3.3.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "7.18.8",
    "@react-navigation/elements": "2.9.30",
    "@react-navigation/native": "7.3.8",
    "@react-navigation/native-stack": "7.17.10",
    "@versemark/core": "workspace:*",
    "expo": "55.0.27",
    "expo-haptics": "55.0.15",
    "expo-image": "55.0.11",
    "expo-sqlite": "55.0.17",
    "expo-status-bar": "55.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.25.0",
    "react-native-web": "0.21.2"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@types/react": "19.2.17",
    "eslint": "9.39.2",
    "eslint-config-expo": "55.0.1",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}

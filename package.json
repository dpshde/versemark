{
  "name": "versemark",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "mobile": "pnpm --filter @versemark/mobile start",
    "mobile:start": "pnpm --filter @versemark/mobile start",
    "web": "pnpm --filter @versemark/web dev",
    "web:build": "pnpm --filter @versemark/web build",
    "dev": "pnpm run web",
    "build": "pnpm --filter @versemark/web build",
    "test": "pnpm --filter @versemark/core test && pnpm --filter @versemark/web test",
    "test:core": "pnpm --filter @versemark/core test",
    "typecheck": "pnpm --filter @versemark/core typecheck && pnpm --filter @versemark/web typecheck && pnpm --filter @versemark/mobile typecheck",
    "typecheck:core": "pnpm --filter @versemark/core typecheck",
    "build:data": "pnpm --filter @versemark/web build:data",
    "export:mobile": "pnpm --filter @versemark/mobile export"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "path-scurry>lru-cache": "^10.4.3"
    }
  },
  "overrides": {
    "path-scurry": {
      "lru-cache": "^10.4.3"
    }
  }
}
